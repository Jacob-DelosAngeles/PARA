{
  "expo": {
    "name": "PARA",
    "slug": "para-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "para",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.para.app",
      "config": {
        "googleMapsApiKey": "$(EXPO_PUBLIC_GMAPS_KEY)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00236f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.para.app",
      "config": {
        "googleMaps": {
          "apiKey": "$(EXPO_PUBLIC_GMAPS_KEY)"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00236f",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PARA needs your location to show nearby jeepneys.",
          "locationWhenInUsePermission": "PARA needs your location to show nearby jeepneys."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PARA needs access to your photos for report images.",
          "cameraPermission": "PARA needs camera access to take report photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00236f",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
